import {
  "moonbitlang/core/env",
  "moonbitlang/core/json",
  "moonbitlang/x/fs",
  "moonbitlang/x/sys",
  "starlittle/MoonEvidence/src/model",
  "starlittle/MoonEvidence/src/verify",
  "starlittle/MoonEvidence/src/diag",
  "starlittle/MoonEvidence/src/create",
  "starlittle/MoonEvidence/src/digest",
  "starlittle/MoonEvidence/src/canonjson",
}

options(
  "is-main": true,
  "native-stub": [ "native_stub.c" ],
  targets: {
    "main_native.mbt": [ "native", "llvm" ],
    "main_js.mbt": [ "js" ],
    "main_wasm.mbt": [ "wasm", "wasm-gc" ],
  },
)
